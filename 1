---

- hosts: all
  become: yes

  tasks:

    - name: Install web packages on Debian family
      ansible.builtin.apt:
        name:
          - apache2
          - libapache2-mod-php
        state: present
        update_cache: yes
      when: ansible_os_family == "Debian"

    - name: Install web packages on RedHat family
      ansible.builtin.dnf:
        name:
          - httpd
          - php
        state: present
        update_cache: yes
      when: ansible_os_family == "RedHat" 
 


